    // Видаляє кириличні дужки (переклади назв), зберігає характеристики (колір, матеріал, об'єм).
    // Правило: кирилична дужка видаляється якщо після неї є текст АБО числова дужка з текстом
    // (наприклад (40000 Затяжок)). Залишається якщо вона остання або після неї тільки залишок (число).
    function removeCyrillicBrackets(text) {
        const tokens = [];
        let last = 0;
        const rx = /\(([^)]*)\)/g;
        let m;
        while ((m = rx.exec(text)) !== null) {
            if (m.index > last) tokens.push({ type: 'text', val: text.slice(last, m.index) });
            const inner = m[1].trim();
            tokens.push({
                type: 'bracket', val: m[0], inner,
                isCyrillic:  /^[а-яґєіїА-ЯҐЄІЇ''. ]+$/u.test(inner),
                isRemainder: /^\d+$/.test(inner),   // тільки число — залишок товару
                hasDigit:    /\d/.test(inner)
            });
            last = m.index + m[0].length;
        }
        if (last < text.length) tokens.push({ type: 'text', val: text.slice(last) });

        let result = '';
        for (let i = 0; i < tokens.length; i++) {
            const t = tokens[i];
            if (t.type === 'text') { result += t.val; continue; }
            if (!t.isCyrillic)    { result += t.val; continue; }
            const rest = tokens.slice(i + 1);
            const hasTextAfter           = rest.some(r => r.type === 'text' && r.val.trim().length > 0);
            const hasNonRemainderNumBracket = rest.some(r => r.type === 'bracket' && r.hasDigit && !r.isRemainder);
            result += (hasTextAfter || hasNonRemainderNumBracket) ? '' : t.val;
        }
        return result.replace(/\s{2,}/g, ' ').trim();
    }

    function cleanTitles() {
        if (!get('enableFilter') && !get('removeCyrillicBrackets')) return;
        const words = get('enableFilter')
            ? get('stopWords').split(',').map(s => s.trim()).filter(Boolean)
            : [];
        const esc = s => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const rxs = words.map(w => new RegExp(`(?<!\\p{L})${esc(w)}(?!\\p{L})`, 'giu'));
        const doBrackets = get('removeCyrillicBrackets');
        document.querySelectorAll('td.form-shipment-store-right-table-tbody-td-8').forEach(td => {
            const walker = document.createTreeWalker(td, NodeFilter.SHOW_TEXT);
            const nodes = []; let n;
            while ((n = walker.nextNode())) nodes.push(n);
            nodes.forEach(node => {
                let t = node.textContent;
                rxs.forEach(r => { t = t.replace(r, ''); });
                if (doBrackets) t = removeCyrillicBrackets(t);
                node.textContent = t.replace(/\s+/g, ' ').trim();
            });
        });
    }

