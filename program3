            { width:'100%', padding:'8px', marginBottom:'12px', background:'#0984e3', color:'#fff', border:'none', cursor:'pointer', borderRadius:'6px', fontSize:'13px' });
        const loadSwStatus = makeHint(get('stopWordsUrl') ? '(завантажується при старті)' : '(URL не задано)');
        loadSwStatus.style.marginTop = '-8px';

        loadSwBtn.addEventListener('click', () => {
            const url = stopWordsUrlInput.value.trim();
            if (!url) { loadSwStatus.textContent = '❌ URL порожній'; return; }
            loadSwStatus.textContent = '⏳ Завантаження...';
            fetch(url).then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.text(); })
                .then(text => {
                    const words = parseRemoteWords(text).trim();
                    stopWordsInput.value = words;
                    set('stopWords', words);
                    loadSwStatus.textContent = '✅ Завантажено ' + words.split(',').filter(s => s.trim()).length + ' слів';
                })
                .catch(err => { loadSwStatus.textContent = '❌ ' + err.message; });
        });
        append(loadSwBtn, loadSwStatus);
        append(makeLabel('Стоп-слова (через кому):'));
        const stopWordsInput = makeInput('textarea', get('stopWords'), 'одноразка, elf bar, hqd');
        stopWordsInput.rows = 3;
        append(stopWordsInput, makeHint('Видаляються цілі слова незалежно від регістру'));

        // Інше
        append(makeDivider('⚙️ Інше'));
        append(makeLabel('Кнопка миші для пошуку:'));
        const mouseSelect = makeSelect([
            { value:0, text:'Ліва' }, { value:1, text:'Середня' }, { value:2, text:'Права' }
        ], get('mouseButton'));
        mouseSelect.addEventListener('change', () => { set('mouseButton', parseInt(mouseSelect.value, 10)); });
        append(mouseSelect);

        // Мітка кальяну
        append(makeDivider('Мітка кальян/колба'));
        append(makeHint('Шукає слова у товарах і додає мітку до "Нова пошта" на сторінці відвантаження.'));
        append(makeLabel('Слова кальяну (через кому):'));
        const hookahWordsInput = makeInput('text', get('hookahWords') || 'кальян', 'кальян, кальяни');
        append(hookahWordsInput);
        append(makeLabel('Слова колби (через кому):'));
        const flaskWordsInput = makeInput('text', get('flaskWords') || 'колба', 'колба, колби');
        append(flaskWordsInput);
        append(makeLabel('Тестове слово (порожньо = вимкнено):'));
        const hookahTestInput = makeInput('text', get('hookahTestWord'), 'вугілля');
        append(hookahTestInput);

        // ── Секція: JSONBin ──
        append(makeDivider('☁️ Хмарна синхронізація'));

        const syncStatusEl = makeHint('', '#aaa');
        const lastSync = parseInt(localStorage.getItem(JSONBIN_SYNC_KEY) || '0', 10);
        syncStatusEl.textContent = lastSync
            ? `Остання синхронізація: ${new Date(lastSync).toLocaleString('uk-UA')}`
            : 'Ще не синхронізувалось';
        append(syncStatusEl);

        const syncRow = css(document.createElement('div'), { display:'flex', gap:'8px', marginBottom:'14px' });

        const syncBtn = css(Object.assign(document.createElement('button'), { textContent: '🔄 Синхронізувати' }), {
            flex:'1', padding:'9px', background:'#0984e3', color:'#fff',
            border:'none', borderRadius:'8px', cursor:'pointer', fontSize:'13px'
        });
        syncBtn.addEventListener('click', async () => {
            syncBtn.textContent = '⏳ Завантаження...';
            syncBtn.disabled = true;
            await syncFromJsonBin(true);
            syncStatusEl.textContent = `Остання синхронізація: ${new Date().toLocaleString('uk-UA')}`;
            // Оновлюємо поле стоп-слів якщо воно вже відмальоване
            stopWordsInput.value = get('stopWords');
            syncBtn.textContent = '✅ Готово';
            setTimeout(() => { syncBtn.textContent = '🔄 Синхронізувати'; syncBtn.disabled = false; }, 2000);
        });

        const saveCloudBtn = css(Object.assign(document.createElement('button'), { textContent: '💾 Зберегти в хмару' }), {
            flex:'1', padding:'9px', background:'#6c5ce7', color:'#fff',
            border:'none', borderRadius:'8px', cursor:'pointer', fontSize:'13px'
        });
        saveCloudBtn.addEventListener('click', async () => {
            saveCloudBtn.textContent = '⏳ Збереження...';
            saveCloudBtn.disabled = true;
            const words = stopWordsInput.value.trim().split(',').map(s => s.trim()).filter(Boolean);
            const ok = await saveToJsonBin({
                barcodes: barcodeMap,
                stopWords: words,
                features
            });
            saveCloudBtn.textContent = ok ? '✅ Збережено' : '❌ Помилка';
            setTimeout(() => { saveCloudBtn.textContent = '💾 Зберегти в хмару'; saveCloudBtn.disabled = false; }, 2000);
        });

        syncRow.appendChild(syncBtn);
        syncRow.appendChild(saveCloudBtn);
        append(syncRow);
        append(makeHint('Синхронізується автоматично раз на добу о 12:00', '#888'));

        // ── Секретна кнопка ──
        const secretBtn = css(Object.assign(document.createElement('button'), { textContent: 'Не чіпати' }), {
            width:'100%', padding:'8px', marginTop:'4px', marginBottom:'14px',
            background:'rgba(255,255,255,0.04)', color:'rgba(255,255,255,0.2)',
            border:'1px solid rgba(255,255,255,0.07)',
            borderRadius:'8px', cursor:'pointer', fontSize:'11px',
            letterSpacing:'2px', textTransform:'uppercase',
            transition:'all 0.3s'
        });
        secretBtn.addEventListener('mouseover', () => {
            secretBtn.style.color = 'rgba(255,255,255,0.5)';
            secretBtn.style.borderColor = 'rgba(255,255,255,0.2)';
        });
        secretBtn.addEventListener('mouseout', () => {
            secretBtn.style.color = 'rgba(255,255,255,0.2)';
            secretBtn.style.borderColor = 'rgba(255,255,255,0.07)';
        });
        secretBtn.addEventListener('click', () => {
            window.open('https://www.gaymenring.com/ru/categories', '_blank');
        });
        append(secretBtn);

        // Кнопка Застосувати
        const applyBtn = css(Object.assign(document.createElement('button'), { textContent: 'Застосувати та закрити' }),
            { width:'100%', padding:'12px', marginTop:'8px', background:'#4CAF50', color:'#fff', border:'none', cursor:'pointer', borderRadius:'8px', fontSize:'15px', fontWeight:'600' });

        applyBtn.addEventListener('click', () => {
            set('soundNormalUrl',  soundNormalInput.value.trim());
            set('soundHighUrl',    soundHighInput.value.trim()   || '/alarm.mp3');
            set('minSoundCount',   parseInt(minSoundInput.value, 10) || 0);
            set('volume',          parseInt(volumeSlider.value, 10));
            set('enableFilter',          filterCb.checked);
            set('removeCyrillicBrackets', bracketsCb.checked);
            set('stopWords',       stopWordsInput.value.trim());
            set('stopWordsUrl',    stopWordsUrlInput.value.trim());
            set('hookahWords',     hookahWordsInput.value.trim());
            set('flaskWords',      flaskWordsInput.value.trim());
            set('hookahTestWord',  hookahTestInput.value.trim());

            HOOKAH_KEYWORDS.length = 0; FLASK_KEYWORDS.length = 0;
            get('hookahWords').split(',').forEach(w => { const t = w.trim().toLowerCase(); if (t) HOOKAH_KEYWORDS.push(t); });
            get('flaskWords').split(',').forEach(w => { const t = w.trim().toLowerCase(); if (t) FLASK_KEYWORDS.push(t); });

            const lbl = document.querySelector('h1.form-shipment-store-table-left-shipment-method');
            if (lbl) delete lbl.dataset.rulikSuffix;

            applyAudioSettings(); applyTheme();
            panel.style.opacity = '0'; panel.style.transform = 'translateY(-20px)';
            setTimeout(() => { panel.style.display = 'none'; }, 300);
            toggleBtn.textContent = 'Rulik Mod';
        });
        append(applyBtn);

        document.body.appendChild(toggleBtn);
        document.body.appendChild(panel);
    }

    // ── Аварійна кнопка синхронізації (завжди видима, навіть якщо enabled:false) ──
    function createEmergencySyncBtn() {
        const btn = document.createElement('button');
        btn.textContent = '☁';
        btn.title = 'Rulik Mod: примусова синхронізація з хмарою';
        btn.dataset.rulikEmergency = '1';
        Object.assign(btn.style, {
            position: 'fixed', bottom: '20px', left: '20px', zIndex: '10001',
            width: '32px', height: '32px', borderRadius: '50%',
            background: 'rgba(9,132,227,0.15)', color: 'rgba(9,132,227,0.5)',
            border: '1px solid rgba(9,132,227,0.2)',
            cursor: 'pointer', fontSize: '14px',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            transition: 'all 0.3s', lineHeight: '1'
        });
        btn.addEventListener('mouseover', () => {
            btn.style.background = 'rgba(9,132,227,0.8)';
            btn.style.color = '#fff';
            btn.style.transform = 'scale(1.15)';
        });
        btn.addEventListener('mouseout', () => {
            btn.style.background = 'rgba(9,132,227,0.15)';
            btn.style.color = 'rgba(9,132,227,0.5)';
            btn.style.transform = 'scale(1)';
        });
        btn.addEventListener('click', async () => {
            btn.textContent = '⏳';
            btn.style.pointerEvents = 'none';
            await syncFromJsonBin(true);
            // Якщо після синхронізації features.enabled = true — відновлюємо панель
            if (features.enabled) {
                const toggleBtn = document.querySelector('button[data-rulik-toggle]');
                if (!toggleBtn) {
                    createSettingsPanel();
                    createStatsPanel();
                    applyTheme();
                }
            }
            btn.textContent = '✓';
            setTimeout(() => {
                btn.textContent = '☁';
                btn.style.pointerEvents = '';
            }, 2000);
        });
        document.body.appendChild(btn);
    }
    let observerTimer = null;
    const masterObserver = new MutationObserver(() => {
        if (!features.enabled) return;
        clearTimeout(observerTimer);
        observerTimer = setTimeout(() => {
            if (features.filter)      cleanTitles();
            if (features.barcodes)    replaceAndClearBarcode();
                                      resizeFont();
                                      checkWaitingButtons();
                                      addCopyButtonListeners();
                                      addWeightListener();
            document.querySelectorAll('.form-block-buttons-submit').forEach(btn => {
                if (!btn.dataset.rulikColor) {
                    btn.addEventListener('click', () => btn.style.backgroundColor = randomNonBlueColor());
                    btn.dataset.rulikColor = '1';
                }
            });
            if (features.autoField)   processTable();
            if (features.hookahLabel) applyHookahLabel();
            if (features.sound)       checkWaitingButtons();
                                      createCollectedCheckbox();
                                      addSaveButtonListener();
        }, 200);
    });
    masterObserver.observe(document.body, { childList: true, subtree: true });

    // ── Ініціалізація ──────────────────────────────────────────────────────────
    document.addEventListener('copy', removeBracketsAndNumbers);
    document.body.addEventListener('input', e => { if (features.barcodes) replaceInputValue(e); });
    window.addEventListener('load', () => {
        if (features.sound)     applyAudioSettings();
        if (features.autoField) runWithRetry(processTable);
    });

    // Синхронізація з JSONBin (першочергово, потім ініціалізація)
    syncFromJsonBin().then(() => {
        setTimeout(() => {
            createSettingsPanel(); createStatsPanel();
            if (features.theme)  applyTheme();
                                 setupVideoBackground();
            if (get('snowEnabled')) createSnowfall();
            createEffect(get('activeEffect'));
            if (features.sound)  applyAudioSettings();
                                 loadRemoteStopWords();
            if (features.filter) cleanTitles();
                                 resizeFont();
                                 checkWaitingButtons();
                                 addCopyButtonListeners();
                                 addWeightListener();
            if (features.hookahLabel) applyHookahLabel();
                                      createCollectedCheckbox();
            applyFeatures();
        }, 1000);
    });

})();
