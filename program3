    };

    // Єдиний <style> тег — завжди перезаписуємо, не накопичуємо
    let themeStyleEl = null;

    function applyTheme() {
        if (!themeStyleEl) {
            themeStyleEl = document.createElement('style');
            themeStyleEl.id = 'rulik-theme';
            document.head.appendChild(themeStyleEl);
        }

        const name = get('theme');
        const t = themes[name];

        // Скидаємо фон body окремо (бо може бути відео або картинка)
        if (!get('backgroundEnabled') || !t) {
            document.body.style.backgroundColor = '';
            document.body.style.backgroundImage = 'none';
        }

        if (!t) {
            // theme = off — прибираємо всі наші стилі
            themeStyleEl.textContent = '';
            return;
        }

        // Фон сторінки
        if (get('backgroundEnabled')) {
            if (get('backgroundImageUrl')) {
                document.body.style.backgroundImage = `url("${get('backgroundImageUrl')}")`;
                document.body.style.backgroundSize = 'cover';
                document.body.style.backgroundRepeat = 'no-repeat';
                document.body.style.backgroundAttachment = 'fixed';
                document.body.style.backgroundColor = '';
            } else {
                document.body.style.backgroundColor = t.bg;
                document.body.style.backgroundImage = 'none';
            }
        }

        // Панель налаштувань
        const panel = document.querySelector('.settings-panel');
        if (panel) { panel.style.background = t.panel; panel.style.color = t.panelText; }

        // CSS з !important — перебиває Vue inline styles та Tailwind
        themeStyleEl.textContent = `
            /* Rulik Mod Theme: ${name} */

            /* Фон сторінки */
            body, #app { background-color: ${t.bg} !important; }

            /* Навбар */
            nav.menu-items {
                background-color: ${t.nav} !important;
                background: ${t.nav} !important;
            }
            .nav-menu-btn, .nav-menu-btn-span,
            nav.menu-items a, nav.menu-items button, nav.menu-items span {
                color: ${t.navText} !important;
            }
            nav.menu-items a:hover, nav.menu-items button:hover {
                color: ${t.accent} !important;
                background-color: rgba(255,255,255,0.08) !important;
            }

            /* Кнопки дії */
            .base-button:not(.nav-menu-btn):not(.button-red-style) {
                background-color: ${t.accent}22 !important;
                color: ${t.accent} !important;
                border: 1px solid ${t.accent}55 !important;
            }
            .base-button:not(.nav-menu-btn):not(.button-red-style):hover {
                background-color: ${t.accent}44 !important;
            }
            .button-grant-style { color: #fff !important; }

            /* Таблиця — фон і текст окремо щоб не зливались */
            table, .form-shipment-store-table-right-div-table,
            tr, td, th,
            .form-shipment-store-right-table-tbody-td-8,
            .form-shipment-store-right-table-tbody-td-2,
            .form-shipment-store-right-table-thead-th-8,
            .form-shipment-store-right-table-thead-th-2 {
                background-color: ${t.table} !important;
                color: ${t.tableText} !important;
            }
            tr:nth-child(even) td { filter: brightness(0.93); }

            /* Заголовок */
            h1.form-title { color: ${t.text} !important; }

            /* Ліва панель форми */
            .form-shipment-store-table-left,
            .form-shipment-store-table-left-label,
            .form-shipment-store-table-left-row-control {
                color: ${t.text} !important;
                background-color: transparent !important;
            }

            /* Блоки-обгортки */
            .form-wrapper-form-wrapper, .form-shipment-store-table {
                background-color: ${t.bg} !important;
            }

            /* Посилання */
            a:not(.nav-menu-btn):not(.base-button) { color: ${t.accent} !important; }

            /* Не чіпаємо input/select/textarea */
        `;
    }

    // ── Відео-фон ──────────────────────────────────────────────────────────────
    function setupVideoBackground() {
        if (!get('videoBackgroundEnabled')) return;
        const v = document.createElement('video');
        v.src = get('videoUrl'); v.autoplay = v.loop = v.muted = true;
        Object.assign(v.style, { position:'fixed', top:0, left:0, width:'100%', height:'100%', objectFit:'cover', zIndex:'-1' });
        document.body.appendChild(v);
    }
    function removeVideoBackground() {
        document.querySelector('video[style*="z-index"]')?.remove();
    }

    // ── Ефекти (сніг, дощ, листя, бульбашки, зірки, серця, конфеті, вогонь) ──
    const EFFECT_CONTAINER_ID = 'rulik-effect-container';

    function removeEffect() {
        document.getElementById(EFFECT_CONTAINER_ID)?.remove();
        document.getElementById('rulik-effect-style')?.remove();
    }

    function createEffect(name) {
        removeEffect();
        if (!name || name === 'none') return;

        const style = document.createElement('style');
        style.id = 'rulik-effect-style';
        document.head.appendChild(style);

        const container = document.createElement('div');
        container.id = EFFECT_CONTAINER_ID;
        Object.assign(container.style, {
            position: 'fixed', top: '0', left: '0', width: '100%', height: '100%',
            pointerEvents: 'none', zIndex: '9997', overflow: 'hidden'
        });
        document.body.appendChild(container);

        if (name === 'snow') {
            style.textContent = `
                @keyframes rulik-snow {
                    0%   { transform: translateY(-10px) translateX(0) rotate(0deg); opacity: 1; }
                    50%  { transform: translateY(50vh) translateX(30px) rotate(180deg); }
                    100% { transform: translateY(105vh) translateX(-10px) rotate(360deg); opacity: 0.4; }
                }
            `;
            for (let i = 0; i < 80; i++) {
                const f = document.createElement('div');
                const size = Math.random() * 7 + 3;
                Object.assign(f.style, {
                    position: 'absolute',
                    left: `${Math.random() * 100}%`,
                    top: `-${size}px`,
                    width: `${size}px`, height: `${size}px`,
                    background: get('snowflakeColor') || 'white',
                    borderRadius: '50%',
                    opacity: Math.random() * 0.6 + 0.4,
                    animationName: 'rulik-snow',
                    animationDuration: `${Math.random() * 4 + 5}s`,
                    animationDelay: `${Math.random() * 8}s`,
                    animationTimingFunction: 'linear',
                    animationIterationCount: 'infinite'
                });
                container.appendChild(f);
            }
        }

        else if (name === 'rain') {
            style.textContent = `
                @keyframes rulik-rain {
                    0%   { transform: translateY(-20px); opacity: 0.8; }
                    100% { transform: translateY(105vh); opacity: 0.3; }
                }
            `;
            for (let i = 0; i < 80; i++) {
                const f = document.createElement('div');
                const h = Math.random() * 18 + 8;
                Object.assign(f.style, {
                    position: 'absolute',
                    left: `${Math.random() * 100}%`,
                    top: `-${h}px`,
                    width: `${Math.random() * 1.5 + 0.5}px`, height: `${h}px`,
                    background: 'linear-gradient(to bottom, transparent, rgba(174,214,241,0.85))',
                    borderRadius: '0 0 2px 2px',
                    animationName: 'rulik-rain',
                    animationDuration: `${Math.random() * 0.4 + 0.3}s`,
                    animationDelay: `${Math.random() * 4}s`,
                    animationTimingFunction: 'linear',
                    animationIterationCount: 'infinite'
                });
                container.appendChild(f);
            }
        }

        else if (name === 'leaves') {
            style.textContent = `
                @keyframes rulik-leaf-fall {
                    0%   { transform: translateY(-30px) translateX(0) rotate(0deg);   opacity: 1; }
                    25%  { transform: translateY(25vh)  translateX(80px) rotate(90deg); }
                    50%  { transform: translateY(50vh)  translateX(-50px) rotate(190deg); }
                    75%  { transform: translateY(75vh)  translateX(60px) rotate(270deg); }
                    100% { transform: translateY(105vh) translateX(10px) rotate(360deg); opacity: 0.2; }
                }
            `;
            const emojis = ['🍂','🍁','🍃','🌿','🍀'];
            for (let i = 0; i < 35; i++) {
                const f = document.createElement('div');
                Object.assign(f.style, {
                    position: 'absolute',
                    left: `${Math.random() * 100}%`,
                    top: '-30px',
                    fontSize: `${Math.random() * 12 + 14}px`,
                    animationName: 'rulik-leaf-fall',
                    animationDuration: `${Math.random() * 5 + 7}s`,
                    animationDelay: `${Math.random() * 12}s`,
                    animationTimingFunction: 'ease-in',
                    animationIterationCount: 'infinite'
                });
                f.textContent = emojis[Math.floor(Math.random() * emojis.length)];
                container.appendChild(f);
            }
        }

        else if (name === 'bubbles') {
            style.textContent = `
                @keyframes rulik-bubble-rise {
                    0%   { transform: translateY(0) scale(1);    opacity: 0; }
                    10%  { opacity: 0.7; }
                    90%  { opacity: 0.5; }
                    100% { transform: translateY(-105vh) scale(1.1); opacity: 0; }
                }
                @keyframes rulik-bubble-sway {
                    0%,100% { margin-left: 0; }
                    33%     { margin-left: 20px; }
                    66%     { margin-left: -20px; }
                }
            `;
            for (let i = 0; i < 30; i++) {
                const wrap = document.createElement('div');
                const size = Math.random() * 35 + 10;
                Object.assign(wrap.style, {
                    position: 'absolute',
                    left: `${Math.random() * 95}%`,
                    bottom: `-${size}px`,
                    width: `${size}px`, height: `${size}px`,
                    animationName: 'rulik-bubble-rise',
                    animationDuration: `${Math.random() * 5 + 5}s`,
                    animationDelay: `${Math.random() * 10}s`,
                    animationTimingFunction: 'linear',
                    animationIterationCount: 'infinite'
                });
                // Внутрішня куля з переливом
                const inner = document.createElement('div');
                const hue = Math.floor(Math.random() * 360);
                Object.assign(inner.style, {
                    width: '100%', height: '100%',
                    borderRadius: '50%',
                    border: `1px solid hsla(${hue},80%,80%,0.6)`,
                    background: `radial-gradient(circle at 30% 30%, hsla(${hue},80%,90%,0.4), hsla(${hue},60%,60%,0.05))`,
                    boxShadow: `inset 2px 2px 4px rgba(255,255,255,0.3)`,
                    animationName: 'rulik-bubble-sway',
                    animationDuration: `${Math.random() * 2 + 2}s`,
                    animationTimingFunction: 'ease-in-out',
                    animationIterationCount: 'infinite'
                });
                wrap.appendChild(inner);
                container.appendChild(wrap);
            }
        }

        else if (name === 'stars') {
            style.textContent = `
                @keyframes rulik-twinkle {
                    0%,100% { opacity: 0.15; transform: scale(0.8); }
                    50%     { opacity: 1;    transform: scale(1.3); }
                }
                @keyframes rulik-shoot {
                    0%   { transform: translateX(0) translateY(0) rotate(45deg); opacity: 1; width: 80px; }
                    100% { transform: translateX(300px) translateY(300px) rotate(45deg); opacity: 0; width: 5px; }
                }
            `;
            // Статичні зірки
            for (let i = 0; i < 120; i++) {
                const f = document.createElement('div');
                const size = Math.random() * 2.5 + 0.5;
                Object.assign(f.style, {
                    position: 'absolute',
                    left: `${Math.random() * 100}%`,
                    top: `${Math.random() * 100}%`,
                    width: `${size}px`, height: `${size}px`,
                    borderRadius: '50%',
                    background: `hsl(${Math.random()*60+200},80%,90%)`,
                    animationName: 'rulik-twinkle',
                    animationDuration: `${Math.random() * 3 + 1.5}s`,
                    animationDelay: `${Math.random() * 5}s`,
                    animationTimingFunction: 'ease-in-out',
                    animationIterationCount: 'infinite'
                });
                container.appendChild(f);
            }
            // Падаючі зірки — окремий шар
            for (let i = 0; i < 6; i++) {
                const f = document.createElement('div');
                Object.assign(f.style, {
                    position: 'absolute',
                    left: `${Math.random() * 60}%`,
                    top: `${Math.random() * 40}%`,
                    width: '80px', height: '2px',
                    background: 'linear-gradient(to right, rgba(255,255,255,0.9), transparent)',
                    borderRadius: '2px',
                    animationName: 'rulik-shoot',
                    animationDuration: `${Math.random() * 1.5 + 0.8}s`,
                    animationDelay: `${i * 3 + Math.random() * 5}s`,
                    animationTimingFunction: 'ease-in',
                    animationIterationCount: 'infinite'
                });
                container.appendChild(f);
            }
        }

        else if (name === 'hearts') {
            style.textContent = `
                @keyframes rulik-heart {
                    0%   { transform: translateY(0) scale(0.5) rotate(-10deg); opacity: 0; }
                    15%  { opacity: 1; }
                    85%  { opacity: 0.6; }
                    100% { transform: translateY(-105vh) scale(1) rotate(10deg); opacity: 0; }
                }
            `;
            for (let i = 0; i < 25; i++) {
                const f = document.createElement('div');
                const hue = Math.random() > 0.5 ? 350 : 320;
                Object.assign(f.style, {
                    position: 'absolute',
                    left: `${Math.random() * 96}%`,
                    bottom: '-40px',
                    fontSize: `${Math.random() * 18 + 12}px`,
                    color: `hsl(${hue},90%,65%)`,
                    animationName: 'rulik-heart',
                    animationDuration: `${Math.random() * 4 + 5}s`,
                    animationDelay: `${Math.random() * 10}s`,
                    animationTimingFunction: 'ease-out',
                    animationIterationCount: 'infinite'
                });
                f.textContent = Math.random() > 0.3 ? '❤️' : '💕';
                container.appendChild(f);
            }
        }

        else if (name === 'confetti') {
            style.textContent = `
                @keyframes rulik-confetti {
                    0%   { transform: translateY(-10px) rotate(0deg);   opacity: 1; }
                    100% { transform: translateY(105vh) rotate(720deg); opacity: 0.3; }
                }
            `;
            const colors = ['#ff6b6b','#ffd93d','#6bcb77','#4d96ff','#c77dff','#ff9f43','#fd79a8'];
            for (let i = 0; i < 70; i++) {
                const f = document.createElement('div');
                const isRect = Math.random() > 0.5;
                const size = Math.random() * 8 + 5;
                Object.assign(f.style, {
                    position: 'absolute',
                    left: `${Math.random() * 100}%`,
                    top: `-${size}px`,
                    width: isRect ? `${size}px` : `${size * 0.5}px`,
                    height: isRect ? `${size * 0.4}px` : `${size}px`,
                    background: colors[Math.floor(Math.random() * colors.length)],
                    borderRadius: isRect ? '2px' : '50%',
                    animationName: 'rulik-confetti',
                    animationDuration: `${Math.random() * 3 + 3}s`,
                    animationDelay: `${Math.random() * 6}s`,
                    animationTimingFunction: 'linear',
                    animationIterationCount: 'infinite'
                });
                container.appendChild(f);
            }
        }

        else if (name === 'fire') {
            style.textContent = `
                @keyframes rulik-fire {
                    0%   { transform: translateY(0) scaleX(1)   rotate(-3deg); opacity: 0.9; }
                    33%  { transform: translateY(-30px) scaleX(1.2) rotate(3deg); }
                    66%  { transform: translateY(-60px) scaleX(0.8) rotate(-2deg); opacity: 0.6; }
                    100% { transform: translateY(-100px) scaleX(0.5) rotate(0deg); opacity: 0; }
                }
            `;
            for (let i = 0; i < 40; i++) {
                const f = document.createElement('div');
                const size = Math.random() * 30 + 15;
                const hue  = Math.random() * 40; // 0–40 = червоний–жовтий
                Object.assign(f.style, {
                    position: 'absolute',
