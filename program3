                        filter: 'blur(0.5px)',
                        animationName: 'rulik-splat-in, rulik-splat-fade',
                        animationDuration: `0.4s, ${lifetime * 0.85}ms`,
                        animationTimingFunction: 'ease-out, linear',
                        animationFillMode: 'forwards, forwards'
                    });
                    group.appendChild(sp);
                }

                // Потік вниз (1–3 краплі)
                const dripCount = Math.floor(Math.random() * 2) + 1;
                for (let d = 0; d < dripCount; d++) {
                    const dripX = (Math.random() - 0.5) * size * 0.6;
