            boxShadow:'0 8px 24px rgba(0,0,0,.5)', border:'1px solid rgba(255,255,255,.12)',
            display:'none', overflowY:'auto', fontFamily:"'Segoe UI',Arial,sans-serif", fontSize:'13px'
        });

        function toggleStats() {
            const hidden = statsPanel.style.display === 'none';
            if (hidden) { renderStats(); statsPanel.style.display = 'block'; }
            else statsPanel.style.display = 'none';
        }

        function renderStats() {
            const data = parseTableStats();
            statsPanel.innerHTML = '';

            const h = Object.assign(document.createElement('div'), {
                style: 'display:flex;justify-content:space-between;align-items:center;margin-bottom:12px'
            });
            h.innerHTML = '<b style="font-size:15px">📊 Статистика по співробітниках</b>';
            const closeBtn = Object.assign(document.createElement('button'), { textContent: '✖' });
            Object.assign(closeBtn.style, { background:'rgba(255,255,255,.1)', border:'none', color:'#fff', cursor:'pointer', borderRadius:'6px', padding:'2px 8px', fontSize:'14px' });
            closeBtn.addEventListener('click', toggleStats);
            h.appendChild(closeBtn);
            statsPanel.appendChild(h);

            if (!data) {
                statsPanel.insertAdjacentHTML('beforeend', '<div style="color:#ffeaa7">⚠ Таблиця не знайдена або порожня</div>');
                return;
            }

            let grandTotal = 0, grandCount = 0;
            Object.values(data).forEach(s => { grandTotal += s.total; grandCount += s.count; });

            statsPanel.insertAdjacentHTML('beforeend', `
                <div style="background:rgba(255,255,255,.07);border-radius:8px;padding:10px;margin-bottom:14px">
                    <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="opacity:.7">Всього рядків:</span><b>${grandCount}</b></div>
                    <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="opacity:.7">Загальна сума:</span><b style="color:#55efc4">${formatNum(grandTotal)} ₴</b></div>
                    <div style="display:flex;justify-content:space-between"><span style="opacity:.7">Середній чек:</span><b>${formatNum(Math.round(grandTotal/grandCount))} ₴</b></div>
                </div>
            `);

            Object.entries(data).sort((a, b) => b[1].total - a[1].total).forEach(([name, s]) => {
                const avg = Math.round(s.total / s.count);
                const pct = grandTotal > 0 ? (s.total / grandTotal * 100).toFixed(1) : 0;
                const sa  = [...s.amounts].sort((a, b) => a - b);
                const mid = Math.floor(sa.length / 2);
                const med = sa.length % 2 ? sa[mid] : Math.round((sa[mid-1] + sa[mid]) / 2);
                const card = document.createElement('div');
                card.style.cssText = 'background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 12px;margin-bottom:10px';
                card.innerHTML = `
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2px">
                        <b style="font-size:14px">${name}</b><span style="color:#74b9ff;font-size:12px">${pct}%</span>
                    </div>
                    <div style="background:rgba(255,255,255,.1);border-radius:4px;height:4px;margin:6px 0 10px">
                        <div style="width:${pct}%;background:linear-gradient(90deg,#00cec9,#0984e3);border-radius:4px;height:100%"></div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px 8px;font-size:12px;opacity:.9">
                        <span>📦 Замовлень: <b>${s.count}</b></span>
                        <span>💰 Сума: <b style="color:#55efc4">${formatNum(s.total)} ₴</b></span>
                        <span>📈 Середній: <b>${formatNum(avg)} ₴</b></span>
                        <span>📉 Медіана: <b>${formatNum(med)} ₴</b></span>
                        <span>🔺 Макс: <b>${formatNum(s.max)} ₴</b></span>
                        <span>🔻 Мін: <b>${formatNum(s.min)} ₴</b></span>
                    </div>
                `;
                statsPanel.appendChild(card);
            });

            const refreshBtn = Object.assign(document.createElement('button'), { textContent: '🔄 Оновити' });
            Object.assign(refreshBtn.style, { width:'100%', padding:'8px', marginTop:'4px', background:'rgba(255,255,255,.1)', color:'#fff', border:'1px solid rgba(255,255,255,.2)', borderRadius:'6px', cursor:'pointer', fontSize:'13px' });
            refreshBtn.addEventListener('click', renderStats);
            statsPanel.appendChild(refreshBtn);
        }

        // Чіт-код "rulik"
        let cheatBuf = '', cheatTimer = null;
        document.addEventListener('keydown', e => {
            clearTimeout(cheatTimer);
            cheatBuf = (cheatBuf + e.key.toLowerCase()).slice(-5);
            if (cheatBuf === 'rulik') { cheatBuf = ''; toggleStats(); }
            cheatTimer = setTimeout(() => { cheatBuf = ''; }, 1500);
        });

        document.body.appendChild(statsPanel);
    }

