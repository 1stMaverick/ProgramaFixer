    function parseTableStats() {
        const rows = document.querySelectorAll('table.crud-table-style tbody tr');
        if (!rows.length) return null;
        const stats = {};
        rows.forEach(row => {
            const cells = row.querySelectorAll('td.crud-table-tbody-tr-td-info');
            if (cells.length < 9) return;
            const name = cells[1]?.textContent.trim();
            const sum  = parseInt(cells[8]?.textContent.replace(/\s/g, ''), 10);
            if (!name || isNaN(sum)) return;
            const s = stats[name] ??= { total: 0, count: 0, max: -Infinity, min: Infinity, amounts: [] };
            s.total += sum; s.count++; s.amounts.push(sum);
            if (sum > s.max) s.max = sum;
            if (sum < s.min) s.min = sum;
        });
        return Object.keys(stats).length ? stats : null;
    }

    function createStatsPanel() {
        const statsPanel = document.createElement('div');
        Object.assign(statsPanel.style, {
            position:'fixed', bottom:'160px', left:'20px', width:'360px', maxHeight:'80vh',
            background:'linear-gradient(145deg,#1e272e,#2f3640)', color:'#dfe6e9',
