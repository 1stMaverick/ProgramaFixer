        if (!force) {
            const last = parseInt(localStorage.getItem(JSONBIN_SYNC_KEY) || '0', 10);
            const now  = Date.now();
            const noon = (() => {
                const d = new Date();
                d.setHours(12, 0, 0, 0);
                // Якщо вже після 12 — беремо сьогоднішній noon, інакше вчорашній
                return d.getTime() > now ? d.getTime() - 86400000 : d.getTime();
            })();
            if (last >= noon) return; // вже синхронізували після останнього noon
        }

        try {
            const r = await fetch(JSONBIN_URL + '/latest', {
                headers: { 'X-Master-Key': JSONBIN_KEY }
            });
            if (!r.ok) throw new Error('HTTP ' + r.status);
            const data = (await r.json()).record;

            // Оновлюємо штрихкоди
            if (data.barcodes && typeof data.barcodes === 'object') {
                barcodeMap = { ...fallbackBarcodeMap, ...data.barcodes };
                console.log('[RulikMod] ✅ Штрихкоди оновлено з JSONBin:', Object.keys(barcodeMap).length);
