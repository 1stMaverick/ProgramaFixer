    // Читає поточний bin і повертає весь record
    async function fetchBinRecord() {
        const r = await fetch(JSONBIN_URL + '/latest', {
            headers: { 'X-Master-Key': JSONBIN_KEY }
        });
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return (await r.json()).record;
    }

    async function setCollected(orderId, isCollected) {
        try {
            const record = await fetchBinRecord();
            const collected = record.collected || {};
            if (isCollected) {
                collected[orderId] = true;
            } else {
                delete collected[orderId];
            }
            await saveToJsonBin({ ...record, collected });
        } catch (err) {
            console.warn('[RulikMod] ❌ Помилка збереження collected:', err.message);
        }
    }

    async function isCollected(orderId) {
        try {
            const record = await fetchBinRecord();
            return !!(record.collected && record.collected[orderId]);
        } catch {
            return false;
        }
    }

