                    animationDuration: `0.35s, ${lifetime}ms`,
                    animationTimingFunction: 'ease-out, linear',
                    animationFillMode: 'forwards, forwards'
                });
                group.appendChild(blob);

                // Бризки навколо (4–7 штук)
                const splashCount = Math.floor(Math.random() * 4) + 4;
                for (let s = 0; s < splashCount; s++) {
                    const angle = (s / splashCount) * 360;
                    const dist  = size * 0.5 + Math.random() * size * 0.3;
                    const sSize = Math.random() * size * 0.25 + size * 0.1;
                    const sp = document.createElement('div');
                    const rad = angle * Math.PI / 180;
                    Object.assign(sp.style, {
                        position: 'absolute',
                        width:  `${sSize}px`,
                        height: `${sSize * 0.8}px`,
                        borderRadius: '50%',
                        background: `rgba(255,255,255,${Math.random() * 0.3 + 0.5})`,
