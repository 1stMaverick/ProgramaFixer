                        background: `rgba(255,255,255,${Math.random() * 0.2 + 0.6})`,
                        transformOrigin: 'top center',
                        animationName: 'rulik-splat-drip',
                        animationDuration: `${lifetime * 0.9}ms`,
                        animationDelay: `${Math.random() * 200}ms`,
                        animationTimingFunction: 'ease-in',
                        animationFillMode: 'forwards'
                    });
                    group.appendChild(drip);
                }

                container.appendChild(group);
                setTimeout(() => group.remove(), lifetime + 500);
            }

            // Перший сплеск одразу, далі з інтервалом
            spawnSplat();
            const splatInterval = setInterval(() => {
                if (!document.getElementById(EFFECT_CONTAINER_ID)) {
